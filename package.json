{
  "name": "cricket-3d-live",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx server/mock-ws-server.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx server/mock-ws-server.ts",
    "build": "tsc && vite build",
    "install:models": "node scripts/install-cricket-models.mjs",
    "generate:bowling": "node scripts/generate-bowling-motion.mjs",
    "inspect:fbx": "node scripts/inspect-fbx.mjs",
    "meshy:balance": "node scripts/meshy-api.mjs balance",
    "meshy:search": "node scripts/meshy-api.mjs search",
    "meshy:build-bowler": "node scripts/meshy-api.mjs build-bowler",
    "meshy:retexture": "node scripts/meshy-api.mjs retexture",
    "meshy:kit-bowler": "node scripts/meshy-api.mjs kit-bowler",
    "meshy:prebuild-kits": "node scripts/meshy-api.mjs prebuild-kits",
